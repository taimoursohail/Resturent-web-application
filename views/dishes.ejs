<!DOCTYPE html>
<html lang="en">

<%- include('./partials/header.ejs') %>

    <body>
        <header style="background-color: #1a1a1a; border-bottom: 2px solid #c5a059;">
            <h1 class="logo serif gold-text" style="font-size: 2rem;">L'Éclat Admin</h1>
            <p class="tagline" style="font-size: 0.9rem;">Dish Management System</p>
        </header>

        <nav>
            <ul class="nav-links">
                <li><a href="/">🏠 Back to Menu</a></li>
                <li><a href="/admin/dishes" class="nav-active">🍽️ Manage Dishes</a></li>
                <li><a href="/admin/orders" class="nav-link-orders">📋 View Orders</a></li>
            </ul>
        </nav>

        <section class="container" style="padding: 3rem 2rem;">
            <h2 class="section-title gold-text">Manage Menu Items</h2>

            <!-- Add New Dish Form -->
            <div class="admin-section">
                <h3 class="gold-text">Add New Dish</h3>
                <form id="addDishForm" class="admin-form">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="dishName">Dish Name *</label>
                            <input type="text" id="dishName" name="name" required placeholder="e.g., Truffle Pizza">
                        </div>
                        <div class="form-group">
                            <label for="dishPrice">Price ($) *</label>
                            <input type="number" id="dishPrice" name="price" step="0.01" required placeholder="28.50">
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="dishCategory">Category *</label>
                            <select id="dishCategory" name="category" required>
                                <option value="">Select a category</option>
                                <option value="appetizers">Appetizers</option>
                                <option value="mains">Main Courses</option>
                                <option value="desserts">Desserts</option>
                                <option value="drinks">Drinks</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="dishImage">Image URL (Optional)</label>
                            <input type="url" id="dishImage" name="image" placeholder="https://example.com/image.jpg">
                        </div>
                    </div>

                    <div class="form-group full-width">
                        <label for="dishDescription">Description *</label>
                        <textarea id="dishDescription" name="description" required rows="4"
                            placeholder="Describe the dish..."></textarea>
                    </div>

                    <button type="submit" class="btn-submit">Add Dish</button>
                </form>
            </div>

            <!-- Existing Dishes by Category -->
            <div class="admin-section">
                <h3 class="gold-text">Existing Dishes</h3>

                <% Object.keys(menuData).forEach(category=> { %>
                    <div class="category-section">
                        <h4 class="gold-text" style="text-transform: capitalize; margin-top: 2rem;">
                            <%= category %> (<%= menuData[category].length %> items)
                        </h4>

                        <% if (menuData[category].length===0) { %>
                            <p style="color: #a0a0a0;">No items in this category</p>
                            <% } else { %>
                                <div class="dishes-grid">
                                    <% menuData[category].forEach(dish=> { %>
                                        <div class="dish-card" data-id="<%= dish.id %>" data-category="<%= category %>">
                                            <div class="dish-header">
                                                <h5 class="dish-name">
                                                    <%= dish.name %>
                                                </h5>
                                                <span class="dish-price">$<%= dish.price.toFixed(2) %></span>
                                            </div>

                                            <p class="dish-description">
                                                <%= dish.description %>
                                            </p>
                                            <img src="<%= dish.image %>" alt="<%= dish.name %>"
                                                class="dish-thumbnail" />

                                            <div class="dish-actions">
                                                <button class="btn-edit" data-id="<%= dish.id %>"
                                                    data-category="<%= category %>" data-name="<%= dish.name %>"
                                                    data-price="<%= dish.price %>"
                                                    data-description="<%= dish.description %>"
                                                    data-image="<%= dish.image %>"
                                                    onclick="editDishFromButton(this)">Edit</button>
                                                <button class="btn-delete" data-id="<%= dish.id %>"
                                                    onclick="deleteDishFromButton(this)">Delete</button>
                                            </div>
                                        </div>
                                        <% }); %>
                                </div>
                                <% } %>
                    </div>
                    <% }); %>
            </div>
        </section>

        <!-- Edit Dish Modal -->
        <div id="editModal" class="modal" style="display: none;">
            <div class="modal-content">
                <span class="close" onclick="closeEditModal()">&times;</span>
                <h2 class="gold-text">Edit Dish</h2>
                <form id="editDishForm" class="admin-form">
                    <input type="hidden" id="editDishId">
                    <input type="hidden" id="editDishOldCategory">

                    <div class="form-row">
                        <div class="form-group">
                            <label for="editDishName">Dish Name</label>
                            <input type="text" id="editDishName" name="name" placeholder="Dish name">
                        </div>
                        <div class="form-group">
                            <label for="editDishPrice">Price ($)</label>
                            <input type="number" id="editDishPrice" name="price" step="0.01" placeholder="Price">
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="editDishCategory">Category</label>
                            <select id="editDishCategory" name="category">
                                <option value="appetizers">Appetizers</option>
                                <option value="mains">Main Courses</option>
                                <option value="desserts">Desserts</option>
                                <option value="drinks">Drinks</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="editDishImage">Image URL</label>
                            <input type="url" id="editDishImage" name="image" placeholder="Image URL">
                        </div>
                    </div>

                    <div class="form-group full-width">
                        <label for="editDishDescription">Description</label>
                        <textarea id="editDishDescription" name="description" rows="4"
                            placeholder="Description"></textarea>
                    </div>

                    <div style="display: flex; gap: 1rem;">
                        <button type="submit" class="btn-submit">Save Changes</button>
                        <button type="button" class="btn-cancel" onclick="closeEditModal()">Cancel</button>
                    </div>
                </form>
            </div>
        </div>

        <%- include('./partials/footer.ejs') %>

            <style>
                .admin-section {
                    background-color: #0d0d0d;
                    padding: 2rem;
                    border-radius: 8px;
                    border: 1px solid #c5a05922;
                    margin-bottom: 3rem;
                }

                .admin-form {
                    display: flex;
                    flex-direction: column;
                    gap: 1rem;
                }

                .form-row {
                    display: grid;
                    grid-template-columns: 1fr 1fr;
                    gap: 1rem;
                }

                .form-group {
                    display: flex;
                    flex-direction: column;
                    gap: 0.5rem;
                }

                .form-group.full-width {
                    grid-column: 1 / -1;
                }

                .form-group label {
                    color: #c5a059;
                    font-weight: 600;
                    font-size: 0.95rem;
                }

                .form-group input,
                .form-group textarea,
                .form-group select {
                    padding: 0.8rem;
                    background-color: #1a1a1a;
                    border: 1px solid #c5a05922;
                    color: #e0e0e0;
                    border-radius: 4px;
                    font-family: inherit;
                    font-size: 0.95rem;
                }

                .form-group input:focus,
                .form-group textarea:focus,
                .form-group select:focus {
                    outline: none;
                    border-color: #c5a059;
                    background-color: #2a2a2a;
                }

                .btn-submit {
                    background-color: #c5a059;
                    color: #0a0a0a;
                    border: none;
                    padding: 0.8rem 1.5rem;
                    border-radius: 4px;
                    cursor: pointer;
                    font-weight: 600;
                    text-transform: uppercase;
                    letter-spacing: 1px;
                    transition: all 0.3s ease;
                }

                .btn-submit:hover {
                    background-color: #e6c86f;
                    transform: translateY(-2px);
                }

                .btn-cancel {
                    background-color: #2a2a2a;
                    color: #e0e0e0;
                    border: 1px solid #c5a05922;
                    padding: 0.8rem 1.5rem;
                    border-radius: 4px;
                    cursor: pointer;
                    font-weight: 600;
                    text-transform: uppercase;
                    letter-spacing: 1px;
                    transition: all 0.3s ease;
                }

                .btn-cancel:hover {
                    background-color: #3a3a3a;
                    border-color: #c5a059;
                }

                .dishes-grid {
                    display: grid;
                    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
                    gap: 1.5rem;
                    margin-top: 1rem;
                }

                .dish-card {
                    background-color: #1a1a1a;
                    border: 1px solid #c5a05922;
                    border-radius: 8px;
                    padding: 1rem;
                    transition: all 0.3s ease;
                }

                .dish-card:hover {
                    border-color: #c5a059;
                    box-shadow: 0 0 15px rgba(197, 160, 89, 0.15);
                }

                .dish-header {
                    display: flex;
                    justify-content: space-between;
                    align-items: baseline;
                    margin-bottom: 0.5rem;
                    border-bottom: 1px solid #c5a05922;
                    padding-bottom: 0.5rem;
                }

                .dish-name {
                    color: #fff;
                    font-weight: 600;
                    margin: 0;
                }

                .dish-price {
                    color: #c5a059;
                    font-weight: 700;
                }

                .dish-description {
                    color: #a0a0a0;
                    font-size: 0.85rem;
                    line-height: 1.4;
                    margin: 0.5rem 0;
                    max-height: 60px;
                    overflow: hidden;
                }

                .dish-thumbnail {
                    width: 100%;
                    height: 150px;
                    object-fit: cover;
                    border-radius: 4px;
                    margin: 0.5rem 0;
                    border: 1px solid #c5a05922;
                }

                .dish-actions {
                    display: flex;
                    gap: 0.5rem;
                    margin-top: 1rem;
                }

                .btn-edit,
                .btn-delete {
                    flex: 1;
                    padding: 0.6rem;
                    border: none;
                    border-radius: 4px;
                    cursor: pointer;
                    font-weight: 600;
                    font-size: 0.85rem;
                    text-transform: uppercase;
                    letter-spacing: 0.5px;
                    transition: all 0.3s ease;
                }

                .btn-edit {
                    background-color: #c5a05922;
                    color: #c5a059;
                    border: 1px solid #c5a059;
                }

                .btn-edit:hover {
                    background-color: #c5a059;
                    color: #0a0a0a;
                }

                .btn-delete {
                    background-color: #ff6b6b22;
                    color: #ff6b6b;
                    border: 1px solid #ff6b6b;
                }

                .btn-delete:hover {
                    background-color: #ff6b6b;
                    color: #fff;
                }

                .category-section {
                    margin-bottom: 2rem;
                }

                .modal {
                    position: fixed;
                    z-index: 1000;
                    left: 0;
                    top: 0;
                    width: 100%;
                    height: 100%;
                    background-color: rgba(0, 0, 0, 0.8);
                    display: flex;
                    align-items: center;
                    justify-content: center;
                }

                .modal-content {
                    background-color: #1a1a1a;
                    padding: 2rem;
                    border: 1px solid #c5a05933;
                    border-radius: 8px;
                    width: 90%;
                    max-width: 600px;
                    max-height: 80vh;
                    overflow-y: auto;
                    color: #e0e0e0;
                }

                .close {
                    color: #c5a059;
                    float: right;
                    font-size: 2rem;
                    font-weight: bold;
                    cursor: pointer;
                    line-height: 1;
                }

                .close:hover {
                    color: #e6c86f;
                }

                @media (max-width: 768px) {
                    .form-row {
                        grid-template-columns: 1fr;
                    }

                    .dishes-grid {
                        grid-template-columns: 1fr;
                    }

                    .admin-form {
                        gap: 0.5rem;
                    }
                }
            </style>

            <script>
                const categories = ['appetizers', 'mains', 'desserts', 'drinks'];

                document.getElementById('addDishForm').addEventListener('submit', addDish);
                document.getElementById('editDishForm').addEventListener('submit', updateDish);

                function addDish(e) {
                    e.preventDefault();

                    const formData = {
                        name: document.getElementById('dishName').value,
                        price: document.getElementById('dishPrice').value,
                        description: document.getElementById('dishDescription').value,
                        category: document.getElementById('dishCategory').value,
                        image: document.getElementById('dishImage').value || ''
                    };

                    fetch('/api/dishes', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(formData)
                    })
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                alert('Dish added successfully!');
                                document.getElementById('addDishForm').reset();
                                location.reload();
                            } else {
                                alert('Error: ' + data.error);
                            }
                        })
                        .catch(err => {
                            console.error('Error:', err);
                            alert('Failed to add dish');
                        });
                }

                function editDishFromButton(button) {
                    const id = button.dataset.id;
                    const category = button.dataset.category;
                    const name = button.dataset.name;
                    const price = button.dataset.price;
                    const description = button.dataset.description;
                    const image = button.dataset.image;
                    editDish(id, category, name, price, description, image);
                }

                function editDish(id, category, name, price, description, image) {
                    document.getElementById('editDishId').value = id;
                    document.getElementById('editDishOldCategory').value = category;
                    document.getElementById('editDishName').value = name;
                    document.getElementById('editDishPrice').value = price;
                    document.getElementById('editDishDescription').value = description;
                    document.getElementById('editDishCategory').value = category;
                    document.getElementById('editDishImage').value = image;
                    document.getElementById('editModal').style.display = 'flex';
                }

                function closeEditModal() {
                    document.getElementById('editModal').style.display = 'none';
                }

                function updateDish(e) {
                    e.preventDefault();

                    const dishId = document.getElementById('editDishId').value;
                    const formData = {
                        name: document.getElementById('editDishName').value,
                        price: document.getElementById('editDishPrice').value,
                        description: document.getElementById('editDishDescription').value,
                        category: document.getElementById('editDishCategory').value,
                        image: document.getElementById('editDishImage').value
                    };

                    fetch(`/api/dishes/${dishId}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(formData)
                    })
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                alert('Dish updated successfully!');
                                closeEditModal();
                                location.reload();
                            } else {
                                alert('Error: ' + data.error);
                            }
                        })
                        .catch(err => {
                            console.error('Error:', err);
                            alert('Failed to update dish');
                        });
                }

                function deleteDishFromButton(button) {
                    const id = button.dataset.id;
                    deleteDish(id);
                }

                function deleteDish(id) {
                    if (confirm('Are you sure you want to delete this dish?')) {
                        fetch(`/api/dishes/${id}`, {
                            method: 'DELETE'
                        })
                            .then(res => res.json())
                            .then(data => {
                                if (data.success) {
                                    alert('Dish deleted successfully!');
                                    location.reload();
                                } else {
                                    alert('Error: ' + data.error);
                                }
                            })
                            .catch(err => {
                                console.error('Error:', err);
                                alert('Failed to delete dish');
                            });
                    }
                }

                window.onclick = function (event) {
                    const modal = document.getElementById('editModal');
                    if (event.target === modal) {
                        closeEditModal();
                    }
                }
            </script>
    </body>

</html>